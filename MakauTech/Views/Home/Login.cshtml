@model MakauTech.Models.LoginViewModel
@{
    ViewData["Title"] = "Login";
}

@section Styles {
<style>
/* ── full-viewport gate, sits above topbar ── */
.city-gate {
    position: fixed;
    inset: 0;
    z-index: 8000;
    display: grid;
    grid-template-columns: 1fr 460px;
    overflow: hidden;
}

/* ─── LEFT: photo panel ─── */
.cg-visual {
    position: relative;
    overflow: hidden;
    background: #060e08;
}
.cg-photo {
    position: absolute;
    inset: 0;
    background-image: url('/Images/rajang-river.jpg');
    background-size: cover;
    background-position: center 40%;
    filter: brightness(0.5) saturate(1.3);
    animation: cg-drift 70s ease-in-out infinite alternate;
    will-change: transform;
}
@@keyframes cg-drift {
    from { transform: scale(1.01) translate(0, 0); }
    to   { transform: scale(1.05) translate(-0.4%, -0.5%); }
}
.cg-overlay {
    position: absolute;
    inset: 0;
    background:
        linear-gradient(to right, rgba(0,0,0,0) 55%, #0d1a10 100%),
        linear-gradient(to top,   rgba(0,20,10,0.85) 0%, transparent 50%);
}
/* floating particles – pure CSS */
.cg-particles {
    position: absolute;
    inset: 0;
    overflow: hidden;
    pointer-events: none;
}
.cg-dot {
    position: absolute;
    width: 3px; height: 3px;
    border-radius: 50%;
    background: rgba(52,211,153,0.55);
    animation: cg-float linear infinite;
}
.cg-dot:nth-child(1)  { left:8%;  bottom:-6px; animation-duration:14s; animation-delay:0s;    width:2px;height:2px; }
.cg-dot:nth-child(2)  { left:22%; bottom:-6px; animation-duration:18s; animation-delay:2.5s; }
.cg-dot:nth-child(3)  { left:37%; bottom:-6px; animation-duration:12s; animation-delay:0.8s; width:4px;height:4px;opacity:.4; }
.cg-dot:nth-child(4)  { left:55%; bottom:-6px; animation-duration:20s; animation-delay:4s;   width:2px;height:2px; }
.cg-dot:nth-child(5)  { left:70%; bottom:-6px; animation-duration:16s; animation-delay:1.2s; }
.cg-dot:nth-child(6)  { left:85%; bottom:-6px; animation-duration:22s; animation-delay:3s;   width:2px;height:2px;opacity:.3; }
.cg-dot:nth-child(7)  { left:14%; bottom:-6px; animation-duration:17s; animation-delay:6s; }
.cg-dot:nth-child(8)  { left:48%; bottom:-6px; animation-duration:13s; animation-delay:1.8s; width:2px;height:2px; }
@@keyframes cg-float {
    0%   { transform: translateY(0) scale(1);   opacity: 0; }
    5%   { opacity: 1; }
    95%  { opacity: .6; }
    100% { transform: translateY(-100vh) scale(0.6); opacity: 0; }
}

.cg-visual-content {
    position: relative;
    z-index: 2;
    height: 100%;
    display: flex;
    flex-direction: column;
    padding: 40px 48px;
}
/* logo top-left */
.cg-logo {
    display: flex;
    align-items: center;
    gap: 10px;
    text-decoration: none;
    width: fit-content;
}
.cg-logo-icon {
    width: 42px; height: 42px;
    border-radius: 11px;
    background: rgba(255,255,255,0.15);
    border: 1.5px solid rgba(255,255,255,0.28);
    backdrop-filter: blur(10px);
    display: grid; place-items: center;
    font-size: 22px;
    box-shadow: 0 4px 16px rgba(0,0,0,0.3);
}
.cg-logo-name {
    font-family: var(--mk-font-display, 'Fraunces', serif);
    font-size: 20px;
    font-weight: 800;
    color: #fff;
    letter-spacing: -0.02em;
    text-shadow: 0 2px 8px rgba(0,0,0,0.4);
}
/* hero center — vertically centered in photo panel */
.cg-hero {
    flex: 1;
    display: flex;
    flex-direction: column;
    justify-content: center;
}
/* live indicator */
.cg-live {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    background: rgba(52,211,153,0.14);
    border: 1px solid rgba(52,211,153,0.3);
    color: #6ee7b7;
    font-size: 10.5px;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    padding: 4px 12px;
    border-radius: 999px;
    backdrop-filter: blur(6px);
    width: fit-content;
    margin-bottom: 20px;
}
/* logo in dark form panel */
.cg-panel-brand {
    display: flex;
    align-items: center;
    gap: 9px;
    margin-bottom: 36px;
}
.cg-panel-brand img { width: 30px; height: 30px; border-radius: 8px; opacity: 0.85; }
.cg-panel-brand-name {
    font-family: var(--mk-font-display, 'Fraunces', serif);
    font-size: 16px;
    font-weight: 800;
    color: rgba(255,255,255,0.55);
    letter-spacing: -0.02em;
}
.cg-live::before {
    content: '';
    width: 6px; height: 6px;
    border-radius: 50%;
    background: #34d399;
    animation: cg-pulse 2s ease infinite;
}
@@keyframes cg-pulse {
    0%,100% { opacity:1; box-shadow:0 0 0 0 rgba(52,211,153,0.5); }
    50%      { opacity:.5; box-shadow:0 0 0 4px rgba(52,211,153,0); }
}
/* big city typography */
.cg-city {
    font-family: var(--mk-font-display, 'Fraunces', serif);
    font-size: clamp(72px, 10vw, 120px);
    font-weight: 900;
    line-height: 0.88;
    letter-spacing: -0.05em;
    margin: 0 0 18px;
    color: #fff;
}
.cg-city span {
    display: block;
    color: transparent;
    -webkit-text-stroke: 1.5px rgba(255,255,255,0.38);
}
.cg-tagline {
    font-size: 15px;
    color: rgba(255,255,255,0.55);
    letter-spacing: 0.04em;
    margin: 0 0 32px;
}
/* coordinate badge */
.cg-coords {
    font-family: 'Courier New', monospace;
    font-size: 11px;
    color: rgba(255,255,255,0.3);
    letter-spacing: 0.1em;
    margin-bottom: 8px;
}
/* stat bar */
.cg-stats {
    display: flex;
    gap: 28px;
    margin-bottom: 0;
}
.cg-stat {}
.cg-stat-n {
    font-family: var(--mk-font-display, 'Fraunces', serif);
    font-size: 28px;
    font-weight: 900;
    color: #fff;
    line-height: 1;
    display: block;
}
.cg-stat-l {
    font-size: 10.5px;
    color: rgba(255,255,255,0.38);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-top: 3px;
    display: block;
}

/* ─── RIGHT: dark form panel ─── */
.cg-form-panel {
    position: relative;
    background: #0d1a10;
    display: flex;
    flex-direction: column;
    overflow-y: auto;
    border-left: 1px solid rgba(52,211,153,0.12);
}
/* shimmer top edge */
.cg-shimmer {
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 2px;
    background: linear-gradient(90deg,
        transparent 0%,
        rgba(52,211,153,0.6) 30%,
        rgba(16,185,129,1) 50%,
        rgba(52,211,153,0.6) 70%,
        transparent 100%);
    background-size: 200% 100%;
    animation: cg-shimmer-move 3s linear infinite;
}
@@keyframes cg-shimmer-move {
    0%   { background-position: -100% 0; }
    100% { background-position: 200% 0; }
}

.cg-form-inner {
    flex: 1;
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 60px 48px;
}

/* back link */
.cg-back {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    color: rgba(255,255,255,0.35);
    font-size: 12px;
    font-weight: 600;
    text-decoration: none;
    letter-spacing: 0.06em;
    margin-bottom: 48px;
    transition: color 0.18s;
}
.cg-back:hover { color: #6ee7b7; }

.cg-form-label {
    font-size: 10.5px;
    font-weight: 800;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: #34d399;
    margin-bottom: 10px;
}
.cg-form-title {
    font-family: var(--mk-font-display, 'Fraunces', serif);
    font-size: clamp(28px, 4vw, 36px);
    font-weight: 800;
    color: #f0fdf4;
    margin: 0 0 6px;
    letter-spacing: -0.03em;
    line-height: 1.1;
}
.cg-form-sub {
    font-size: 13.5px;
    color: rgba(255,255,255,0.35);
    margin: 0 0 36px;
}

/* alert */
.cg-alert {
    background: rgba(239,68,68,0.12);
    border: 1px solid rgba(239,68,68,0.3);
    border-radius: 8px;
    padding: 11px 14px;
    font-size: 13px;
    color: #fca5a5;
    margin-bottom: 24px;
    display: flex;
    align-items: flex-start;
    gap: 8px;
}

/* underline inputs */
.cg-field {
    margin-bottom: 30px;
}
.cg-field-label {
    display: block;
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.35);
    margin-bottom: 10px;
}
.cg-field-wrap {
    position: relative;
}
.cg-field-icon {
    position: absolute;
    left: 0;
    top: 50%;
    transform: translateY(-50%);
    width: 18px; height: 18px;
    color: rgba(255,255,255,0.25);
    pointer-events: none;
    transition: color 0.2s;
}
.cg-input {
    width: 100%;
    background: transparent;
    border: none;
    border-bottom: 1px solid rgba(255,255,255,0.12);
    padding: 10px 0 10px 28px;
    font-size: 15px;
    color: #f0fdf4;
    outline: none;
    transition: border-color 0.2s;
    box-shadow: none;
}
.cg-input::placeholder { color: rgba(255,255,255,0.2); }
.cg-input:focus { border-bottom-color: #34d399; }
.cg-input:focus ~ .cg-field-icon { color: #34d399; }
/* focus underline sweep */
.cg-field-line {
    position: absolute;
    bottom: 0; left: 0;
    height: 1px;
    width: 0;
    background: #34d399;
    transition: width 0.28s ease;
}
.cg-input:focus ~ .cg-field-line { width: 100%; }

/* submit */
.cg-submit {
    width: 100%;
    margin-top: 8px;
    background: linear-gradient(135deg, #10b981, #059669);
    color: #fff;
    border: none;
    border-radius: 10px;
    padding: 15px 22px;
    font-size: 15px;
    font-weight: 700;
    letter-spacing: 0.04em;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    transition: opacity 0.18s, transform 0.15s, box-shadow 0.18s;
    box-shadow: 0 4px 20px rgba(16,185,129,0.3);
    position: relative;
    overflow: hidden;
}
.cg-submit::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(90deg, transparent, rgba(255,255,255,0.12), transparent);
    transform: translateX(-100%);
    transition: transform 0.5s;
}
.cg-submit:hover::after { transform: translateX(100%); }
.cg-submit:hover { opacity: 0.92; transform: translateY(-1px); box-shadow: 0 8px 28px rgba(16,185,129,0.4); }
.cg-submit:active { transform: translateY(0); }
.cg-submit svg { width: 17px; height: 17px; transition: transform 0.2s; }
.cg-submit:hover svg { transform: translateX(4px); }

/* register link */
.cg-register {
    margin-top: 28px;
    text-align: center;
    font-size: 13px;
    color: rgba(255,255,255,0.3);
}
.cg-register a {
    color: #34d399;
    font-weight: 700;
    text-decoration: none;
}
.cg-register a:hover { text-decoration: underline; }

/* ── Mobile ── */
@@media (max-width: 840px) {
    .city-gate {
        grid-template-columns: 1fr;
        grid-template-rows: 220px 1fr;
        position: relative;
        min-height: 100vh;
    }
    .cg-visual-content { padding: 24px 28px; }
    .cg-city { font-size: 56px; }
    .cg-stats { display: none; }
    .cg-live { margin-top: 12px; margin-bottom: 12px; }
    .cg-coords { display: none; }
    .cg-form-inner { padding: 36px 28px; }
    .cg-back { margin-bottom: 28px; }
}
</style>
}

<div class="city-gate">

    <!-- ═══ LEFT: PHOTO PANEL ═══ -->
    <div class="cg-visual">
        <div class="cg-photo"></div>
        <div class="cg-overlay"></div>
        <div class="cg-particles">
            <div class="cg-dot"></div>
            <div class="cg-dot"></div>
            <div class="cg-dot"></div>
            <div class="cg-dot"></div>
            <div class="cg-dot"></div>
            <div class="cg-dot"></div>
            <div class="cg-dot"></div>
            <div class="cg-dot"></div>
        </div>
        <div class="cg-visual-content">
            <a href="/" class="cg-logo">
                <div class="cg-logo-icon">🦢</div>
                <span class="cg-logo-name">MakauTech</span>
            </a>

            <!-- hero block — centered vertically -->
            <div class="cg-hero">
                <span class="cg-live">Live · Sibu, Sarawak</span>
                <p class="cg-coords">1.5555° N &nbsp;·&nbsp; 110.3333° E</p>
                <h2 class="cg-city">
                    SIBU
                    <span>AWAITS</span>
                </h2>
                <p class="cg-tagline">Swan City &nbsp;·&nbsp; Foochow Heritage &nbsp;·&nbsp; Borneo</p>
                <div class="cg-stats">
                    <div class="cg-stat">
                        <span class="cg-stat-n">50+</span>
                        <span class="cg-stat-l">Places</span>
                    </div>
                    <div class="cg-stat">
                        <span class="cg-stat-n">5</span>
                        <span class="cg-stat-l">Games</span>
                    </div>
                    <div class="cg-stat">
                        <span class="cg-stat-n">Free</span>
                        <span class="cg-stat-l">Always</span>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- ═══ RIGHT: FORM PANEL ═══ -->
    <div class="cg-form-panel">
        <div class="cg-shimmer"></div>
        <div class="cg-form-inner">

            <!-- MakauTech brand in form panel -->
            <div class="cg-panel-brand">
                <img src="/Images/icon.png" alt="MakauTech" />
                <span class="cg-panel-brand-name">MakauTech</span>
            </div>

            <a href="/" class="cg-back">
                <svg width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5L3 12m0 0l7.5-7.5M3 12h18"/>
                </svg>
                Back to home
            </a>

            <p class="cg-form-label">Sign in</p>
            <h1 class="cg-form-title">Good to see<br>you again.</h1>
            <p class="cg-form-sub">Enter your details to continue exploring.</p>

            @if (TempData["LoginError"] != null)
            {
                <div class="cg-alert" role="alert">
                    <svg width="15" height="15" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" style="flex-shrink:0;margin-top:1px">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126zM12 15.75h.007v.008H12v-.008z"/>
                    </svg>
                    <span>@TempData["LoginError"]</span>
                </div>
            }
            @if (ViewBag.Error != null)
            {
                <div class="cg-alert" role="alert">
                    <svg width="15" height="15" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" style="flex-shrink:0;margin-top:1px">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126zM12 15.75h.007v.008H12v-.008z"/>
                    </svg>
                    <span>@ViewBag.Error</span>
                </div>
            }

            <form method="post" asp-action="Login" novalidate>
                @Html.AntiForgeryToken()

                <div class="cg-field">
                    <label class="cg-field-label" for="loginEmail">Email address</label>
                    <div class="cg-field-wrap">
                        <input id="loginEmail" class="cg-input" type="email" name="Email"
                               placeholder="you@example.com" autocomplete="email" required />
                        <svg class="cg-field-icon" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75"/>
                        </svg>
                        <div class="cg-field-line"></div>
                    </div>
                </div>

                <div class="cg-field">
                    <label class="cg-field-label" for="loginPassword">Password</label>
                    <div class="cg-field-wrap">
                        <input id="loginPassword" class="cg-input" type="password" name="Password"
                               placeholder="••••••••" autocomplete="current-password" required />
                        <svg class="cg-field-icon" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M16.5 10.5V6.75a4.5 4.5 0 10-9 0v3.75m-.75 11.25h10.5a2.25 2.25 0 002.25-2.25v-6.75a2.25 2.25 0 00-2.25-2.25H6.75a2.25 2.25 0 00-2.25 2.25v6.75a2.25 2.25 0 002.25 2.25z"/>
                        </svg>
                        <div class="cg-field-line"></div>
                    </div>
                </div>

                <button type="submit" class="cg-submit">
                    Enter Sibu
                    <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"/>
                    </svg>
                </button>
            </form>

            <div class="cg-register">
                New to Sibu? <a asp-action="Register">Create your account →</a>
            </div>

        </div>
    </div>

</div>
