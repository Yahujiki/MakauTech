@model MakauTech.Models.LoginViewModel
@{
    ViewData["Title"] = "Login";
}
<div class="mk-auth-shell">
    <div class="mk-auth-card mk-fade-in">
        <div class="mk-auth-emoji" aria-hidden="true">🦢</div>
        <h1 class="mk-auth-title">Welcome back</h1>
        <p class="mk-auth-sub">Login to continue your Sibu exploration.</p>

        @if (TempData["LoginError"] != null)
        {
            <div class="mk-alert mk-alert-error" role="alert">
                <span aria-hidden="true">⚠️</span>
                <span>@TempData["LoginError"]</span>
            </div>
        }
        @if (ViewBag.Error != null)
        {
            <div class="mk-alert mk-alert-error" role="alert">
                <span aria-hidden="true">⚠️</span>
                <span>@ViewBag.Error</span>
            </div>
        }

        <form method="post" asp-action="Login" novalidate>
            <div class="mk-form-group">
                <label for="loginEmail">Email</label>
                <input id="loginEmail" type="email" name="Email" class="mk-form-control"
                       placeholder="you@example.com" autocomplete="email" required />
            </div>
            <div class="mk-form-group">
                <label for="loginPassword">Password</label>
                <input id="loginPassword" type="password" name="Password" class="mk-form-control"
                       placeholder="Your password" autocomplete="current-password" required />
            </div>
            <button type="submit" class="mk-btn mk-btn-primary" style="width:100%; justify-content:center; padding:14px 22px; font-size:16px;">
                Login
            </button>
        </form>

        <div style="text-align:center; margin-top:22px; font-size:14px; color:var(--mk-slate-600);">
            No account? <a asp-action="Register" style="color:var(--mk-emerald-600); font-weight:700;">Register here</a>
        </div>
    </div>
</div>
