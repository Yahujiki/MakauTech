            <div class="db-attract-body">
                <span class="db-attract-icon">⛪</span>
                <h3>Sacred Heart Cathedral</h3>
                <p>The principal Roman Catholic church in Sibu, featuring soaring arched ceilings, stunning stained-glass windows, and a grand altar. A symbol of Sibu's deep interfaith harmony serving Iban, Chinese, and Malay communities.</p>
            </div>
        </div>
    </div>

    <!-- ══════════ FEATURED PLACES ══════════ -->
    <div class="db-divider"><span class="db-divider-icon">📍</span><span class="db-divider-text">FEATURED PLACES TO VISIT</span><span class="db-divider-line"></span></div>

    <div class="db-section-head">
        <h2>Top Rated Spots</h2>
        <a asp-controller="Home" asp-action="Explore">See all →</a>
    </div>
    @if (Model.FeaturedPlaces.Any())
    {
        <div class="places-grid db-places" style="margin-bottom:0;">
            @foreach (var place in Model.FeaturedPlaces)
            {
                var likeCount = Model.LikeCounts.ContainsKey(place.Id) ? Model.LikeCounts[place.Id] : 0;
                <div class="place-card">
                    <div class="place-image-wrap">
                        <img src="@PlaceImageUrl.Resolve(Url, place.ImageUrl)" alt="@place.Name" loading="lazy" onerror="this.onerror=null;this.src='@ph'" />
                        <span class="place-category">@place.Category?.Icon @place.Category?.Name</span>
                    </div>
                    <div class="place-info">
                        <h3>@place.Name</h3>
                        <p class="place-location">📍 @place.Location</p>
                        <p class="place-desc">@(place.Description?.Length > 100 ? place.Description[..100] + "…" : place.Description ?? "")</p>
                        <div class="place-meta">
                            @if (place.Rating > 0) { <span class="place-rating">⭐ @place.Rating.ToString("F1")</span> }
                            @if (likeCount > 0) { <span class="place-likes">❤️ @likeCount</span> }
                        </div>
                        <a asp-controller="Place" asp-action="Detail" asp-route-id="@place.Id" class="btn-visit">View details</a>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <p style="color:rgba(255,255,255,0.4);padding:1.5rem 0;">No places loaded yet — <a asp-controller="Home" asp-action="Explore" style="color:#4ade80;font-weight:700;">browse all places →</a></p>
    }

    <!-- ══════════ LOCAL TIPS ══════════ -->
    <div class="db-divider"><span class="db-divider-icon">💡</span><span class="db-divider-text">LOCAL TIPS &amp; TRAVEL GUIDE</span><span class="db-divider-line"></span></div>

    <div class="db-tips-grid">
        <div class="db-tip">
            <span class="db-tip-icon">🍜</span>
            <div>
                <h4>Foochow Food</h4>
                <p>Don't leave without trying Kampua Mee, Kolo Mee, and Kompia buns. Visit Sibu Central Market early morning for the freshest street food experience.</p>
            </div>
        </div>
        <div class="db-tip">
            <span class="db-tip-icon">🌤️</span>
            <div>
                <h4>Best Time to Visit</h4>
                <p>Sibu enjoys tropical weather year-round (23°C–31°C). Avoid November to February for lighter rainfall. Humidity is high — stay hydrated!</p>
            </div>
        </div>
        <div class="db-tip">
            <span class="db-tip-icon">🚢</span>
            <div>
                <h4>River Transport</h4>
                <p>Sibu is well connected by express boats along the Rajang River. Take a scenic river cruise to explore nearby rural towns and Iban longhouses.</p>
            </div>
        </div>
        <div class="db-tip">
            <span class="db-tip-icon">⛩️</span>
            <div>
                <h4>Temple Visits</h4>
                <p>Sibu has impressive Chinese temples like Tua Pek Kong. Visit for insight into the town's deep spiritual and Foochow cultural heritage.</p>
            </div>
        </div>
        <div class="db-tip">
            <span class="db-tip-icon">🏨</span>
            <div>
                <h4>Accommodation</h4>
                <p>Hotels range from budget to mid-range. Sibu is a great base for exploring rural areas, longhouses, and the Borneo rainforest nearby.</p>
            </div>
        </div>
        <div class="db-tip">
            <span class="db-tip-icon">🛒</span>
            <div>
                <h4>Market Tips</h4>
                <p>Sibu Central Market opens at 6 AM. Bring water, arrive early for the best produce, and explore Iban vendors selling exotic jungle fruits and crafts.</p>
            </div>
        </div>
    </div>

    <!-- ══════════ LEADERBOARD + BADGES ══════════ -->
    <div class="db-divider"><span class="db-divider-icon">🏆</span><span class="db-divider-text">YOUR PROGRESS</span><span class="db-divider-line"></span></div>

    <div class="db-two-col">
        <div>
            <div class="db-section-head" style="margin-bottom:0.85rem;"><h2>Top Explorers</h2><a asp-controller="Home" asp-action="Leaderboard">Full board →</a></div>
            @if (Model.TopThree.Count > 0)
            {
                <div class="db-leader-list">
                    @for (var i = 0; i < Model.TopThree.Count; i++)
                    {
                        var u = Model.TopThree[i];
                        <div class="db-leader-row">
                            <span class="db-leader-rank">@(i == 0 ? "🥇" : i == 1 ? "🥈" : "🥉")</span>
                            <span class="db-leader-name">@u.Name</span>
                            <span class="db-leader-pts">@u.Points pts</span>
                        </div>
                    }
                </div>
            }
            else
            {
                <p style="color:rgba(255,255,255,0.4);font-size:0.88rem;">No scores yet — play games to climb!</p>
            }
        </div>
        <div>
            <div class="db-section-head" style="margin-bottom:0.85rem;"><h2>Badges to Earn</h2><a asp-controller="Home" asp-action="Achievements">All badges →</a></div>
            <div class="db-badges">
                @foreach (var kv in badgeMap)
                {
                    <span class="db-badge">@kv.Value @kv.Key</span>
                }
            </div>
        </div>
    </div>

    </div><!-- end .db-wrap -->
}


@section Scripts {
<script>
(function () {
    // Toast for visit
    const params = new URLSearchParams(window.location.search);
    if (params.get('visited') === 'true') {
        const toast = document.createElement('div');
        toast.className = 'toast toast--success';
        toast.setAttribute('role', 'status');
        toast.textContent = 'Visit recorded! +points earned';
        document.body.appendChild(toast);
        requestAnimationFrame(() => toast.classList.add('toast--show'));
        setTimeout(() => { toast.classList.remove('toast--show'); setTimeout(() => toast.remove(), 300); }, 3000);
    }

    // Animated points counter
    const ptEl = document.getElementById('dash-pts-anim');
    if (ptEl) {
        const target = parseInt(ptEl.dataset.val || '0', 10);
        let current = 0;
        const step = Math.max(1, Math.ceil(target / 40));
        const interval = setInterval(() => {
            current = Math.min(current + step, target);
            ptEl.textContent = current;
            if (current >= target) clearInterval(interval);
        }, 30);
    }

    // Animate progress bar
    const fill = document.getElementById('dbProgressFill');
    if (fill) {
        const pct = fill.dataset.pct || '0';
        setTimeout(() => { fill.style.width = pct + '%'; }, 200);
    }
})();

// ═══════════ TUTORIAL WALKTHROUGH ═══════════
(function() {
    if (localStorage.getItem('makautech-tour-done')) return;
    if (!document.getElementById('tour-stats')) return;

    const steps = [
        {
            target: null,
            title: 'Welcome to MakauTech! 🦢',
            text: 'Let us give you a quick tour so you know how everything works.',
            position: 'center'
        },
        {
            target: '#tour-stats',
            title: 'Your Stats 📊',
            text: 'Track your progress here — points earned, places visited, games played, and badges unlocked.',
            position: 'bottom'
        },
        {
            target: '#tour-explore',
            title: 'Explore Sibu 📍',
            text: 'Discover 16 amazing places in Sibu — temples, nature reserves, food spots, and more. Visit places to earn points!',
            position: 'bottom'
        },
        {
            target: '#tour-games',
            title: 'Play Games 🎮',
            text: 'Play fun mini games like Spin & Win, Memory Flip, and Kitchen Rush. Each game earns you up to 50 points!',
            position: 'bottom'
        },
        {
            target: null,
            title: "You're all set! 🎉",
            text: 'Explore places, play games, earn points, and climb the leaderboard. Have fun discovering Sibu!',
            position: 'center'
        }
    ];

    let current = 0;

    // Inject CSS
    const style = document.createElement('style');
    style.textContent = `
        .tour-overlay{position:fixed;inset:0;z-index:9998;pointer-events:none;}
        .tour-backdrop{position:fixed;inset:0;background:rgba(0,0,0,0.7);z-index:9997;transition:opacity 0.3s;}
        .tour-highlight{position:absolute;z-index:9999;border-radius:16px;box-shadow:0 0 0 4px #22c55e,0 0 0 9999px rgba(0,0,0,0.7);transition:all 0.4s ease;pointer-events:none;}
        .tour-tooltip{position:fixed;z-index:10000;background:#111;border:1.5px solid rgba(34,197,94,0.4);border-radius:16px;padding:1.5rem;max-width:320px;width:calc(100vw - 2rem);color:#fff;box-shadow:0 20px 60px rgba(0,0,0,0.5);animation:tourFadeIn 0.3s ease;}
        .tour-tooltip.center{top:50%;left:50%;transform:translate(-50%,-50%);}
        .tour-tooltip h3{font-size:1.1rem;font-weight:800;margin-bottom:0.4rem;color:#4ade80;}
        .tour-tooltip p{font-size:0.88rem;color:rgba(255,255,255,0.75);line-height:1.6;margin-bottom:1rem;}
        .tour-footer{display:flex;justify-content:space-between;align-items:center;gap:0.5rem;}
        .tour-dots{display:flex;gap:0.35rem;}
        .tour-dot{width:7px;height:7px;border-radius:50%;background:rgba(255,255,255,0.2);}
        .tour-dot.active{background:#22c55e;width:18px;border-radius:4px;}
        .tour-btn{padding:0.5rem 1.2rem;border-radius:10px;font-size:0.85rem;font-weight:700;border:none;cursor:pointer;transition:all 0.2s;}
        .tour-btn-next{background:#22c55e;color:#000;}
        .tour-btn-next:hover{background:#16a34a;transform:translateY(-1px);}
        .tour-btn-skip{background:transparent;color:rgba(255,255,255,0.4);font-size:0.78rem;}
        .tour-btn-skip:hover{color:rgba(255,255,255,0.7);}
        .tour-step-count{font-size:0.72rem;color:rgba(255,255,255,0.3);}
        @@keyframes tourFadeIn{from{opacity:0;transform:translate(-50%,-50%) scale(0.95);}to{opacity:1;transform:translate(-50%,-50%) scale(1);}}
    `;
    document.head.appendChild(style);

    function showStep(i) {
        // Remove old
        document.querySelectorAll('.tour-backdrop,.tour-highlight,.tour-tooltip').forEach(e=>e.remove());

        const s = steps[i];
        const isCenter = s.position === 'center' || !s.target;

        // Backdrop
        if (isCenter) {
            const bd = document.createElement('div');
            bd.className = 'tour-backdrop';
            document.body.appendChild(bd);
        }

        // Highlight target
        if (!isCenter && s.target) {
            const el = document.querySelector(s.target);
            if (el) {
                el.scrollIntoView({ behavior:'smooth', block:'center' });
                setTimeout(()=>{
                    const r = el.getBoundingClientRect();
                    const hl = document.createElement('div');
                    hl.className = 'tour-highlight';
                    hl.style.cssText = `top:${r.top+window.scrollY-8}px;left:${r.left-8}px;width:${r.width+16}px;height:${r.height+16}px;`;
                    document.body.appendChild(hl);
                }, 350);
            }
        }

        // Tooltip
        const tip = document.createElement('div');
        tip.className = 'tour-tooltip' + (isCenter ? ' center' : '');
        tip.innerHTML = `
            <h3>${s.title}</h3>
            <p>${s.text}</p>
            <div class="tour-footer">
                <div class="tour-dots">${steps.map((_,j)=>`<div class="tour-dot${j===i?' active':''}"></div>`).join('')}</div>
                <div style="display:flex;gap:0.5rem;align-items:center;">
                    <button class="tour-btn tour-btn-skip" onclick="window._tourSkip()">Skip</button>
                    <button class="tour-btn tour-btn-next" onclick="window._tourNext()">${i===steps.length-1?'Get Started →':'Next'}</button>
                </div>
            </div>
        `;
        document.body.appendChild(tip);

        // Position tooltip near target
        if (!isCenter && s.target) {
            setTimeout(()=>{
                const el = document.querySelector(s.target);
                if (el) {
                    const r = el.getBoundingClientRect();
                    tip.classList.remove('center');
                    tip.style.position = 'absolute';
                    tip.style.top = (r.bottom + window.scrollY + 16) + 'px';
                    tip.style.left = Math.max(16, Math.min(r.left, window.innerWidth - 340)) + 'px';
                    tip.style.transform = 'none';
                    tip.style.animation = 'tourFadeIn 0.3s ease';
                }
            }, 400);
        }
    }

    window._tourNext = function() {
        current++;
        if (current >= steps.length) {
            localStorage.setItem('makautech-tour-done', '1');
            document.querySelectorAll('.tour-backdrop,.tour-highlight,.tour-tooltip').forEach(e=>e.remove());
            return;
        }
        showStep(current);
    };

    window._tourSkip = function() {
        localStorage.setItem('makautech-tour-done', '1');
        document.querySelectorAll('.tour-backdrop,.tour-highlight,.tour-tooltip').forEach(e=>e.remove());
    };

    // Start tour after 1s delay
    setTimeout(() => showStep(0), 1000);
})();
</script>
}
