        <a asp-controller="Home" asp-action="Games" class="db-action db-action--games" id="tour-games"><span class="db-action-icon">🎮</span><span class="db-action-title">Play Games</span><span class="db-action-desc">4 tourism mini games, earn up to 50 pts</span></a>
