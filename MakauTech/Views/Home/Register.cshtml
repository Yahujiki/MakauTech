@model MakauTech.Models.RegisterViewModel
@{
    ViewData["Title"] = "Register";
}
<div class="mk-auth-shell">
    <div class="mk-auth-card mk-fade-in">
        <div class="mk-auth-emoji" aria-hidden="true">🌟</div>
        <h1 class="mk-auth-title">Join MakauTech</h1>
        <p class="mk-auth-sub">Start exploring Sibu and earning rewards.</p>

        @if (ViewBag.Error != null)
        {
            <div class="mk-alert mk-alert-error" role="alert">
                <span aria-hidden="true">⚠️</span>
                <span>@ViewBag.Error</span>
            </div>
        }

        <form method="post" asp-action="Register" novalidate>
            <div class="mk-form-group">
                <label for="regName">Name</label>
                <input id="regName" type="text" name="Name" class="mk-form-control"
                       placeholder="Your full name" autocomplete="name" required />
            </div>
            <div class="mk-form-group">
                <label for="regEmail">Email</label>
                <input id="regEmail" type="email" name="Email" class="mk-form-control"
                       placeholder="you@example.com" autocomplete="email" required />
            </div>
            <div class="mk-form-group">
                <label for="regPassword">Password</label>
                <input id="regPassword" type="password" name="Password" class="mk-form-control"
                       placeholder="At least 6 characters" autocomplete="new-password" minlength="6" required />
            </div>
            <button type="submit" class="mk-btn mk-btn-primary" style="width:100%; justify-content:center; padding:14px 22px; font-size:16px;">
                Create Account
            </button>
        </form>

        <div style="text-align:center; margin-top:22px; font-size:14px; color:var(--mk-slate-600);">
            Already have an account? <a asp-action="Login" style="color:var(--mk-emerald-600); font-weight:700;">Login here</a>
        </div>
    </div>
</div>
