@{
    ViewData["Title"] = "Privacy Policy";
}

@section Styles {
<style>
body { background: #030d06 !important; }
.main-content { background: #030d06; }
</style>
}

<div class="leg-page">
    <div class="leg-hero">
        <div class="leg-hero-orb leg-hero-orb-1"></div>
        <div class="leg-hero-orb leg-hero-orb-2"></div>
        <span class="leg-hero-kicker">🔒 Privacy &amp; Security</span>
        <h1>Privacy <span>Policy</span></h1>
        <p>Last updated: April 2026 · MakauTech (University Technology Sarawak)</p>
    </div>

    <div class="leg-body">
        <div class="leg-card">
            <div class="leg-card-num">01</div>
            <div class="leg-card-content">
                <h2>What We Collect</h2>
                <p>We store the information you provide when you register or update your settings: name, email, and password (stored so you can sign in). Session data keeps you logged in while you browse. If you upload a profile picture, it is stored as a file on our server linked to your user ID.</p>
            </div>
        </div>

        <div class="leg-card">
            <div class="leg-card-num">02</div>
            <div class="leg-card-content">
                <h2>How We Use It</h2>
                <p>We use your account data to run the site: show your profile, points, reviews, and games. We do not sell your personal data. This project is for educational use within UTS.</p>
            </div>
        </div>

        <div class="leg-card">
            <div class="leg-card-num">03</div>
            <div class="leg-card-content">
                <h2>Reviews &amp; Activity</h2>
                <p>Reviews you write are visible to other users as part of the platform. Visit history and points may be shown on leaderboards or your profile as designed by the app.</p>
            </div>
        </div>

        <div class="leg-card">
            <div class="leg-card-num">04</div>
            <div class="leg-card-content">
                <h2>Cookies &amp; Sessions</h2>
                <p>We use server-side sessions (and related cookies if configured) to remember that you are logged in. Essential cookies for authentication are not used for advertising in this coursework version.</p>
            </div>
        </div>

        <div class="leg-card">
            <div class="leg-card-num">05</div>
            <div class="leg-card-content">
                <h2>Security</h2>
                <p>We take reasonable care to protect the demo environment, but no online service is perfectly secure. Use a unique password and do not reuse important passwords from other sites.</p>
            </div>
        </div>

        <div class="leg-card">
            <div class="leg-card-num">06</div>
            <div class="leg-card-content">
                <h2>Your Choices</h2>
                <p>You can update your name, email, or profile photo in Settings. You may request account deletion or data questions through your module instructor for this academic project.</p>
            </div>
        </div>

        <div class="leg-back">
            <a asp-action="Settings" asp-controller="Home" class="leg-back-btn">← Back to Settings</a>
        </div>
    </div>
</div>
