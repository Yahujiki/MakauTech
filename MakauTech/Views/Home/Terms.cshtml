@{
    ViewData["Title"] = "Terms & Conditions";
}

@section Styles {
<style>
body { background: #030d06 !important; }
.main-content { background: #030d06; }
</style>
}

<div class="leg-page">
    <div class="leg-hero">
        <div class="leg-hero-orb leg-hero-orb-1"></div>
        <div class="leg-hero-orb leg-hero-orb-2"></div>
        <span class="leg-hero-kicker">📋 Legal Document</span>
        <h1>Terms &amp; <span>Conditions</span></h1>
        <p>Last updated: April 2026 · MakauTech (University Technology Sarawak)</p>
    </div>

    <div class="leg-body">
        <div class="leg-card">
            <div class="leg-card-num">01</div>
            <div class="leg-card-content">
                <h2>Acceptance</h2>
                <p>By creating an account or using MakauTech, you agree to these terms. If you do not agree, please do not use the service.</p>
            </div>
        </div>

        <div class="leg-card">
            <div class="leg-card-num">02</div>
            <div class="leg-card-content">
                <h2>Purpose</h2>
                <p>MakauTech is an educational tourism discovery platform focused on Sibu, Sarawak. Content (places, images, descriptions) is provided for learning and exploration. It may not be exhaustive or up to date — always verify details before visiting a location.</p>
            </div>
        </div>

        <div class="leg-card">
            <div class="leg-card-num">03</div>
            <div class="leg-card-content">
                <h2>Accounts</h2>
                <p>You are responsible for keeping your login details confidential. You agree to provide accurate information for your profile. We may suspend accounts that abuse the service, spam reviews, or attempt to manipulate points or games.</p>
            </div>
        </div>

        <div class="leg-card">
            <div class="leg-card-num">04</div>
            <div class="leg-card-content">
                <h2>User Content (Reviews)</h2>
                <p>Reviews and comments you post should be respectful and honest. You grant MakauTech permission to display that content on the site as part of the project. Do not post illegal, hateful, or misleading content.</p>
            </div>
        </div>

        <div class="leg-card">
            <div class="leg-card-num">05</div>
            <div class="leg-card-content">
                <h2>Points &amp; Games</h2>
                <p>Points, levels, and badges are gamification features for engagement. They have no cash value. Rules for earning or spending points (e.g. pay-to-play games) may change for coursework or maintenance.</p>
            </div>
        </div>

        <div class="leg-card">
            <div class="leg-card-num">06</div>
            <div class="leg-card-content">
                <h2>Limitation of Liability</h2>
                <p>MakauTech is provided "as is" for academic demonstration. We are not liable for decisions you make based on listings, maps, or third-party information. Travel and visits are at your own risk.</p>
            </div>
        </div>

        <div class="leg-card">
            <div class="leg-card-num">07</div>
            <div class="leg-card-content">
                <h2>Contact</h2>
                <p>For questions about these terms, contact your course team or project supervisor at UTS.</p>
            </div>
        </div>

        <div class="leg-back">
            <a asp-action="Settings" asp-controller="Home" class="leg-back-btn">← Back to Settings</a>
        </div>
    </div>
</div>
